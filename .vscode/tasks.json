{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build hledger-web",
            "type": "shell",
            "command": "stack",
            "args": ["install", "hledger-web"],
            "group": "build",
            "problemMatcher": [],
            "windows": {
                "command": "stack"
            },
            "linux": {
                "command": "stack"
            },
            "osx": {
                "command": "stack"
            }
        },
        {
            "label": "Run hledger-web",
            "type": "shell",
            "command": "hledger-web",
            "group": "build",
            "problemMatcher": [],
            "windows": {
                "command": "hledger-web"
            },
            "linux": {
                "command": "hledger-web"
            },
            "osx": {
                "command": "hledger-web"
            }
        },
        {
            "label": "Check Stack Installation",
            "type": "shell",
            "command": "bash",
            "args": ["-c", "command -v stack || echo 'Stack is not installed. Please install it from https://docs.haskellstack.org/en/stable/README/#how-to-install'"],
            "group": "build",
            "problemMatcher": [],
            "windows": {
                "command": "cmd",
                "args": ["/c", "where stack || echo Stack is not installed. Please install it from https://docs.haskellstack.org/en/stable/README/#how-to-install"]
            },
            "linux": {
                "command": "bash",
                "args": ["-c", "command -v stack || echo 'Stack is not installed. Please install it from https://docs.haskellstack.org/en/stable/README/#how-to-install'"]
            },
            "osx": {
                "command": "bash",
                "args": ["-c", "command -v stack || echo 'Stack is not installed. Please install it from https://docs.haskellstack.org/en/stable/README/#how-to-install'"]
            }
        }
    ]
}
